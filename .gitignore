# ==============================================================================
# BACKEND (Go Artifacts)
# ==============================================================================

# Binaries for programs and plugins
backend/*.exe
backend/*.exe~
backend/*.dll
backend/*.so
backend/*.dylib

# Compiled binary output
backend/main
backend/[A-Za-z0-9_-]

# Test binaries built with 'go test -c'
backend/*.test

# Output of the go coverage tool
backend/*.out
backend/*.prof

# Dependency directories (Uncomment if using vendoring)
# backend/vendor/


# ==============================================================================
# SECRETS & ENVIRONMENT CONFIG
# ==============================================================================
backend/.env
backend/.env.local


# ==============================================================================
# SYSTEM & MISC
# ==============================================================================
.DS_Store
